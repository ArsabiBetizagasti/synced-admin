rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /brands/{slug}/products/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }
    match /adPipelines/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.token.email.matches('.*@synced\\.graphics');
    }
  }
}
